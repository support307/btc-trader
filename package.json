{
  "name": "btc-trader",
  "version": "1.0.0",
  "description": "Autonomous BTC 5-minute prediction market trader on Polymarket",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "btc:start": "tsx src/btc-trader/index.ts",
    "btc:status": "tsx src/btc-trader/index.ts --status",
    "btc:backtest": "tsx src/btc-trader/backtest/run-backtest.ts",
    "btc:backtest:1d": "tsx src/btc-trader/backtest/run-backtest.ts 1",
    "btc:backtest:7d": "tsx src/btc-trader/backtest/run-backtest.ts 7"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "dotenv": "^16.3.1",
    "openai": "^6.27.0",
    "winston": "^3.11.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.2"
  }
}
