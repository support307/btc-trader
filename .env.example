DISCORD_USER_TOKEN=your_discord_user_token
DISCORD_CHANNEL_ID=1018604513856344145
DISCORD_AUTHOR_NAME=Stocksandrealestate
DISCORD_POLL_INTERVAL_MS=3000

# Alpaca Paper Trading (Normal Mode)
ALPACA_API_KEY=your_paper_api_key
ALPACA_API_SECRET=your_paper_api_secret
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets

# Alpaca Live Trading (Safe Mode)
ALPACA_LIVE_API_KEY=your_live_api_key
ALPACA_LIVE_API_SECRET=your_live_api_secret
ALPACA_LIVE_BASE_URL=https://api.alpaca.markets

# Guru-Follow Settings
BUDGET_PERCENT=25
MAX_CONCURRENT_POSITIONS=3
# Notifications (Discord Webhook — primary notification channel)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# LLM Classifier (Anthropic primary, Grok failover)
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE
GROK_API_KEY=xai-YOUR_KEY_HERE
LLM_CLASSIFIER_ENABLED=true
LLM_CLASSIFIER_TIMEOUT_MS=5000

# Monitoring
LOG_LEVEL=info

# ═══════════════════════════════════════════════
# BTC 5-Minute Trader Configuration
# ═══════════════════════════════════════════════

# Polymarket wallet key (export from https://reveal.magic.link/polymarket)
# The CLI also reads from ~/.config/polymarket/config.json
# POLYMARKET_PRIVATE_KEY=0xYOUR_MAGIC_LINK_PRIVATE_KEY

# Trading Settings
BTC_BUDGET_PER_TRADE=1
BTC_MIN_CONFIDENCE=0.60
BTC_MAX_POSITIONS_PER_HOUR=12
BTC_DRY_RUN=false
BTC_EXECUTION_ADAPTER=polymarket  # dry-run | polymarket | alpaca

# RSS.app (optional — for news sentiment analysis)
# RSS_APP_API_KEY=your_rss_app_key
# RSS_APP_API_SECRET=your_rss_app_secret

# Binance (optional — public endpoints work without keys)
# BINANCE_WS_URL=wss://stream.binance.us:9443/ws/btcusd@trade
# BINANCE_REST_URL=https://api.binance.us
