# ═══════════════════════════════════════════════
# BTC 5-Minute Trader Configuration
# ═══════════════════════════════════════════════

# Notifications (Discord Webhook)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# LLM / Sentiment (Grok for X/Twitter sentiment analysis)
GROK_API_KEY=xai-YOUR_KEY_HERE

# Monitoring
LOG_LEVEL=info

# Polymarket wallet key (export from https://reveal.magic.link/polymarket)
# The CLI also reads from ~/.config/polymarket/config.json
POLYMARKET_PRIVATE_KEY=0xYOUR_MAGIC_LINK_PRIVATE_KEY

# Trading Settings
BTC_BUDGET_PER_TRADE=2              # fallback fixed budget (used if BTC_BUDGET_PERCENT is 0)
BTC_BUDGET_PERCENT=25               # % of available balance per trade (dynamic sizing)
BTC_BUDGET_MAX=20                   # max dollars per trade regardless of balance
BTC_MIN_CONFIDENCE=0.60
BTC_MAX_POSITIONS_PER_HOUR=12
BTC_DRY_RUN=false
BTC_EXECUTION_ADAPTER=polymarket    # dry-run | polymarket

# RSS.app (optional — for news sentiment analysis)
# RSS_APP_API_KEY=your_rss_app_key
# RSS_APP_API_SECRET=your_rss_app_secret

# Binance (optional — public endpoints work without keys)
# BINANCE_WS_URL=wss://stream.binance.us:9443/ws/btcusd@trade
# BINANCE_REST_URL=https://api.binance.us
